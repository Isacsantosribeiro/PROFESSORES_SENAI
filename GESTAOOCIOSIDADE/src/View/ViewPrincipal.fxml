<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.ControllerPrincipal">

    <!-- Topo com logo e navegação -->
    <top>
        <HBox spacing="20" style="-fx-padding: 10px; -fx-background-color: #ffffff;">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2463eb;" text="ProfOcioso"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Painel"/>
            <Button text="Perfil do Professor"/>
            <Button text="Gerenciamento de Tarefas"/>
            <Button text="Notificações"/>
            <Button text="Rastreamento de disponibilidade"/>
            <Button style="-fx-background-color: red; -fx-text-fill: white;" text="Sair"/>
        </HBox>
    </top>

    <!-- Conteúdo principal -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20px;">

            <!-- Avatar e nome do usuário -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fitHeight="50" fitWidth="50" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../img/avatar.png"/> <!-- Altere para o caminho da sua imagem -->
                    </image>
                </ImageView>
                <Label fx:id="lblUsuarioLogado" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Bem-vindo, [Usuário]"/>
            </HBox>

            <!-- Título -->
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Painel de Administração"/>

            <!-- Tabela de status dos instrutores -->
            <TableView fx:id="tabelaInstrutores" prefHeight="200" prefWidth="600">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome do Instrutor" prefWidth="200"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
                    <TableColumn fx:id="colDisponibilidade" text="Disponibilidade" prefWidth="250"/>
                </columns>
            </TableView>

            <!-- Formulário para adicionar nova tarefa -->
            <VBox spacing="10" style="-fx-padding: 10; -fx-border-color: #ccc; -fx-border-radius: 5;">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Adicionar nova tarefa"/>

                <HBox spacing="10">
                    <Label text="Instrutor:"/>
                    <ComboBox fx:id="comboInstrutor" promptText="Selecione o instrutor" prefWidth="200"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Descrição da tarefa:"/>
                    <TextField fx:id="txtDescricaoTarefa" promptText="Digite a descrição" prefWidth="300"/>
                </HBox>

                <Button fx:id="btnAdicionarTarefa" text="Adicionar Tarefa"
                        style="-fx-background-color: #2463eb; -fx-text-fill: white;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
